{% extends "base/base.html" %}
{% load crispy_forms_tags humanize %}
{% block title %}Mark Paid{% endblock %}
{% block page_title %}Record Payment{% endblock %}
{% block content %}
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><i class="bi bi-cash me-2 text-success"></i>Record Contribution Payment</div>
      <div class="card-body">
        <div class="alert alert-info mb-4" style="font-size:.88rem;">
          <strong>{{ contribution.member.full_name }}</strong> ({{ contribution.member.member_number }})<br>
          Period: <strong>{{ contribution.period }}</strong><br>
          Amount: <strong>{{ contribution.amount|floatformat:0|intcomma }} ETB</strong>
        </div>
        <form method="post">{% csrf_token %}{% crispy form %}</form>
      </div>
    </div>
  </div>
</div>
{% endblock %}
